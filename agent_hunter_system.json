      "启动所有猎手Agent",
      "监控各Agent发现的任务数量",
      "任务去重和优先级排序",
      "任务价值评估和报价生成",
      "任务分配给执行Agent",
      "进度跟踪和结果汇总"
    ]
  },

  "hunter_agents": [
    {
      "name": "GitHub猎手",

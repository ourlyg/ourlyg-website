  "workflow": {
    "discovery_phase": {
      "duration": "每日执行",
      "agents": ["所有猎手Agent"],
      "output": ["任务发现报告.json"]
    },
    "evaluation_phase": {
      "duration": "任务发现后1小时内",
      "criteria": ["任务评分", "匹配度", "价值评估"],
      "output": ["任务评估报告.json"]
    },
    "quotation_phase": {
      "duration": "评估通过后30分钟内",
      "action": ["生成报价", "联系客户"],
      "output": ["报价单.json"]
    },
    "execution_phase": {
      "duration": "根据任务复杂度",
      "agents": ["执行Agent"],
      "milestones": ["30%确认", "60%确认", "100%交付"],
      "output": ["交付物"]
    },
    "delivery_phase": {
      "duration": "完成后立即",
      "action": ["发送交付物", "收集反馈", "收款确认"],
      "output": ["交付记录.json"]
    }
  },

  "monitoring": {
    "metrics": [
      "任务发现数量/天",
      "任务转化率（发现→报价）",
      "报价转化率（报价→成交）",
      "平均客单价",
      "任务完成时间",
      "客户满意度"
    ],
    "report_frequency": "每日汇总，每周分析"
  }
